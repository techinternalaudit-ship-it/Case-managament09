# ─── Database ───
# SQLite (development)
DATABASE_URL="file:./prisma/dev.db"
# PostgreSQL (production)
# DATABASE_URL="postgresql://vigilance:password@localhost:5432/vigilance"

# ─── Auth ───
AUTH_SECRET="generate-a-random-32-char-string"
AUTH_TRUST_HOST=true
# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# Restrict Google sign-in to this email domain (optional)
GOOGLE_ALLOWED_DOMAIN="paytm.com"

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"
SLA_DAYS_DEFAULT=40

# ─── File Storage ───
# Local (development)
STORAGE_DIR="./uploads"
# S3 (production) — set S3_BUCKET to enable
# S3_BUCKET=""
# S3_REGION="ap-south-1"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""

# ─── Email (SMTP) ───
# Leave SMTP_HOST empty to disable email (logs to console instead)
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
SMTP_FROM="Vigilance <vigilance@paytm.com>"

# ─── AWS SES (alternative to SMTP) ───
# If using SES, set SMTP_HOST to your SES endpoint:
# SMTP_HOST="email-smtp.ap-south-1.amazonaws.com"
# SMTP_PORT=587
# SMTP_USER=<SES SMTP username>
# SMTP_PASS=<SES SMTP password>
