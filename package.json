{
  "name": "vigilance",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-employees": "tsx scripts/seed-employees.ts",
    "db:seed-cases": "tsx scripts/seed-cases.ts",
    "db:seed-all": "npm run db:seed && npm run db:seed-employees && npm run db:seed-cases",
    "db:reset": "prisma db push --force-reset && npm run db:seed-all",
    "render-build": "npm install && npx prisma generate && npx prisma db push && npm run db:seed-all && npm run build",
    "cron:tat": "tsx scripts/tat-scan.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@prisma/client": "^5.22.0",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "next": "^15.0.3",
    "next-auth": "5.0.0-beta.25",
    "nodemailer": "^6.10.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
